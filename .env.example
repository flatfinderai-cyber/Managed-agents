# FlatFinder™ — Environment variables
# Copy this file to `.env.local` (or `.env`) and fill in real values.
# NEVER commit `.env.local` or `.env` — they are gitignored.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL (same value used by both backend and frontend).
SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Service-role key — backend only, never expose to the browser.
SUPABASE_SERVICE_KEY=

# JWT secret (Supabase Dashboard → Settings → API → JWT Settings → JWT Secret).
# Required for backend Bearer-token verification in `deps/supabase_auth.py`.
SUPABASE_JWT_SECRET=

# ── Frontend / CORS ───────────────────────────────────────────────────────────
# Public URL of the Next.js frontend.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Comma-separated list of origins allowed by the backend CORS middleware.
# Leave unset to fall back to NEXT_PUBLIC_APP_URL + localhost defaults.
# Example: CORS_ALLOWED_ORIGINS=https://flatfinder.io,https://www.flatfinder.io
CORS_ALLOWED_ORIGINS=

# ── LLM providers ─────────────────────────────────────────────────────────────
# Anthropic Claude — used by the agent orchestrator (`/api/orchestrator`).
ANTHROPIC_API_KEY=

# Perplexity — used by listing search assist and Benny chat.
PERPLEXITY_API_KEY=
# Optional override; defaults to "sonar".
PERPLEXITY_MODEL=sonar

# Optional: route base_agent.py through OpenRouter instead of Anthropic
# (set AGENT_BACKEND=openrouter to enable).
AGENT_BACKEND=anthropic
OPENROUTER_API_KEY=

# ── Internal API ──────────────────────────────────────────────────────────────
# Shared secret for internal-only endpoints (search-blitz fulfil, orchestrator
# pipeline, human-review actions, stack decisions). Must match the
# `X-Internal-Key` header sent by trusted callers.
INTERNAL_API_KEY=

# ── Scraper ───────────────────────────────────────────────────────────────────
SCRAPER_DELAY_MS=2000
SCRAPER_MAX_LISTINGS=200
# Enable browser-use fallback for stubborn sites (opt-in).
SCRAPER_ENABLE_BROWSER_USE_FALLBACK=false
