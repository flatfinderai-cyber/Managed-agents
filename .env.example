# Copy this file to .env in the repo root and fill in your real values.
# .env is for secrets. .venv is a Python virtual environment folder.
# Never commit .env files.
# Required for Perplexity listing/search flow.
PERPLEXITY_API_KEY=replace_with_your_key

# Only required if you run the Anthropic managed-agent PR flow in pr_agent/.
ANTHROPIC_API_KEY=replace_with_your_key
GITHUB_TOKEN=replace_with_your_github_pat
# Optional override for pr_agent target repository URL.
GITHUB_REPO=https://github.com/flatfinderai-cyber/Managed-agents

# Set by pr_agent/setup.py after first run — do not fill in manually.
# If you use ./run-pr-agent.sh, missing values are created automatically.
MANAGED_AGENT_VAULT_ID=
MANAGED_AGENT_ENV_ID=
MANAGED_AGENT_ID=
MANAGED_AGENT_VERSION=
